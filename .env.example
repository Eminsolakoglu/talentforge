# TalentForge environment variables

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=talentforge
POSTGRES_PASSWORD=talentforge123
POSTGRES_DB=talentforge

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API / UI
API_URL=http://127.0.0.1:8000

# Cloudflare R2 (S3 compatible)
# Example endpoint: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=talentforge-cvs

# LLM backend
# Priority in code: GROQ_API_KEY > HF_TOKEN
GROQ_API_KEY=
HF_TOKEN=
LLM_MODEL=llama-3.1-8b-instant

# App settings
ENV=development
DEBUG=true
SECRET_KEY=super-secret-key-change-in-production
